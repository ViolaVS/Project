# SQLite database file used by Prisma (zero-setup, no server needed).
# To use PostgreSQL instead, set provider="postgresql" in prisma/schema.prisma
# and use a URL like: postgresql://postgres:postgres@localhost:5432/habit_tracker?schema=public
DATABASE_URL="file:./dev.db"

# Secret used to sign JWT auth tokens — change this in production
JWT_SECRET="change-me-to-a-long-random-string"

# Port the API server listens on
PORT=4000

# Origin allowed by CORS (the frontend dev server)
CLIENT_ORIGIN="http://localhost:5173"
